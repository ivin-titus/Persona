{
  "manifest_version": 3,
  "name": "Persona - Multi Account Switcher",
  "version": "1.0.0",
  "description": "Switch between multiple accounts on any site easily.",
  "permissions": [
    "cookies",
    "storage",
    "tabs",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "assets/persona.png",
    "32": "assets/persona.png",
    "48": "assets/persona.png",
    "128": "assets/persona.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Persona Account Switcher",
    "default_icon": "assets/persona.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none';"
  }
}